# Database (Prisma / PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Supabase (Auth & DB)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Upstash (Redis / Rate Limiting)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# PayChangu (Payments)
PAYCHANGU_SECRET_KEY="your-secret-key"
NEXT_PUBLIC_PAYCHANGU_PUBLIC_KEY="your-public-key"


# Email (Nodemailer)
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_USER="user@example.com"
EMAIL_PASS="your-email-password"
EMAIL_FROM="TibhukeBus <noreply@example.com>"


# Encryption
MASTER_ENCRYPTION_KEY="your-64-char-hex-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"
CRON_SECRET="your-32-byte-hex-secret"
