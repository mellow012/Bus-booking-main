generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  uid              String            @unique
  email            String            @unique
  firstName        String
  lastName         String
  phone            String?
  role             String
  nationalId       String?
  sex              String?
  currentAddress   String?
  isActive         Boolean           @default(true)
  emailVerified    Boolean           @default(false)
  setupCompleted   Boolean           @default(false)
  passwordSet      Boolean           @default(false)
  fcmTokens        Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastTokenUpdated DateTime?
  companyId        String?
  region           String?
  invitationSent   Boolean           @default(false)
  invitationSentAt DateTime?
  createdBy        String?
  activities       ActivityLog[]
  bookings         Booking[]
  groupRequests    GroupRequest[]
  notifications    Notification[]
  reservations     SeatReservation[]
  company          Company?          @relation("CompanyStaff", fields: [companyId], references: [id])
}

model Company {
  id                   String             @id @default(uuid())
  name                 String
  email                String
  phone                String?
  address              String?
  description          String?
  logo                 String?
  status               String             @default("active")
  maxBuses             Int                @default(6)
  maxRoutes            Int                @default(3)
  branches             Json?
  contactSettings      Json?
  paymentSettings      Json?
  notificationSettings Json?
  operatingHours       Json?
  setupCompleted       Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  activities           ActivityLog[]
  bookings             Booking[]
  buses                Bus[]
  dailyReports         DailyReport[]
  groupRequests        GroupRequest[]
  routes               Route[]
  schedules            Schedule[]
  scheduleTemplates    ScheduleTemplate[]
  staff                User[]             @relation("CompanyStaff")
}

model Bus {
  id                  String             @id @default(uuid())
  companyId           String
  licensePlate        String
  busType             String
  capacity            Int
  amenities           Json?
  status              String             @default("active")
  yearOfManufacture   Int?
  registrationDetails Json?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  fuelType            String?
  insuranceDetails    Json?
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  company             Company            @relation(fields: [companyId], references: [id])
  schedules           Schedule[]
  scheduleTemplates   ScheduleTemplate[]
}

model Route {
  id                String             @id @default(uuid())
  companyId         String
  name              String
  origin            String
  destination       String
  distance          Int
  duration          Int
  baseFare          Int
  pricePerKm        Int?
  stops             Json?
  isActive          Boolean            @default(true)
  status            String             @default("active")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  groupRequests     GroupRequest[]
  company           Company            @relation(fields: [companyId], references: [id])
  schedules         Schedule[]
  scheduleTemplates ScheduleTemplate[]
}

model Schedule {
  id                String            @id @default(uuid())
  companyId         String
  busId             String
  routeId           String
  departureDateTime DateTime
  arrivalDateTime   DateTime
  departureLocation String?
  arrivalLocation   String?
  availableSeats    Int
  bookedSeats       Json?
  price             Int
  status            String            @default("active")
  tripStatus        String            @default("scheduled")
  isActive          Boolean           @default(true)
  isArchived        Boolean           @default(false)
  isCompleted       Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  baseFare          Int?
  fare              Int?
  segmentPrices     Json?
  bookings          Booking[]
  groupRequests     GroupRequest[]
  bus               Bus               @relation(fields: [busId], references: [id])
  company           Company           @relation(fields: [companyId], references: [id])
  route             Route             @relation(fields: [routeId], references: [id])
  reservations      SeatReservation[]
}

model Booking {
  id               String    @id @default(uuid())
  bookingReference String    @unique
  userId           String
  scheduleId       String
  companyId        String
  totalAmount      Int
  currency         String    @default("MWK")
  bookingStatus    String    @default("pending")
  paymentStatus    String    @default("pending")
  passengerDetails Json?
  seatNumbers      Json?
  paidAt           DateTime?
  bookingDate      DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  cancellationDate DateTime?
  confirmedDate    DateTime?
  contactEmail     String?
  contactPhone     String?
  createdAt        DateTime  @default(now())
  routeId          String?
  company          Company   @relation(fields: [companyId], references: [id])
  schedule         Schedule  @relation(fields: [scheduleId], references: [id])
  user             User      @relation(fields: [userId], references: [id])
  payments         Payment[]
}

model Payment {
  id                String   @id @default(uuid())
  paymentId         String   @unique
  bookingId         String?
  amount            Int
  currency          String   @default("MWK")
  customerEmail     String?
  customerPhone     String?
  checkoutUrl       String?
  status            String   @default("initiated")
  paymentType       String?
  provider          String   @default("paychangu")
  txRef             String?
  metadata          Json?
  paychanguResponse Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  booking           Booking? @relation(fields: [bookingId], references: [id])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  priority  String    @default("medium")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  actionUrl String?
  data      Json?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model SeatReservation {
  id          String   @id @default(uuid())
  scheduleId  String
  userId      String
  seatNumbers Json
  status      String   @default("reserved")
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  schedule    Schedule @relation(fields: [scheduleId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model ScheduleTemplate {
  id            String   @id @default(uuid())
  companyId     String
  routeId       String
  busId         String
  departureTime String
  arrivalTime   String
  daysOfWeek    Json?
  price         Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bus           Bus      @relation(fields: [busId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])
  route         Route    @relation(fields: [routeId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  companyId   String?
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  company     Company? @relation(fields: [companyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model GroupRequest {
  id             String   @id @default(uuid())
  userId         String
  companyId      String
  scheduleId     String
  routeId        String
  organizerName  String
  organizerPhone String
  seatsRequested Int
  totalPrice     Int
  status         String   @default("pending")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id])
  route          Route    @relation(fields: [routeId], references: [id])
  schedule       Schedule @relation(fields: [scheduleId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model DailyReport {
  id                 String   @id @default(uuid())
  companyId          String
  date               DateTime
  createdBy          String
  createdByName      String
  totalSchedules     Int
  completedSchedules Int
  totalBookings      Int
  paidBookings       Int
  boardedPassengers  Int
  noShowPassengers   Int
  totalRevenue       Int
  avgOccupancyRate   Float
  reportData         Json
  createdAt          DateTime @default(now())
  company            Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([date])
}
