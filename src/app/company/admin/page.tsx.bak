import {
  Building2,
  Loader2,
  DollarSign,
  Users,
  Calendar,
  Truck,
  MapPin,
  User,
  Settings,
  AlertTriangle,
  Bell,
  Menu,
  X,
  ChevronRight,
  LayoutDashboard,
  LogOut,
  Search,
  HelpCircle,
  BarChart3,
  PieChart,
} from "lucide-react";
import { driver } from "driver.js";
